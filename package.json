{
  "name": "graphql-rest-rpc-benchmark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hands-on REST/RPC vs GraphQL benchmark playground for flat, nested fan-out, caching, and auth-surface comparisons.",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "bench": "tsx scripts/bench.ts",
    "bench:matrix": "tsx scripts/matrix.ts",
    "cache": "tsx scripts/cache-demo.ts",
    "smoke": "tsx scripts/smoke.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "autocannon": "8.0.0",
    "dataloader": "2.2.3",
    "express": "5.2.1",
    "graphql": "16.11.0"
  },
  "devDependencies": {
    "@types/autocannon": "7.12.7",
    "@types/express": "5.0.6",
    "@types/node": "26.1.0",
    "tsx": "4.23.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
